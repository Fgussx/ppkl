NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-or-anon-key

# Server-only key for admin reads/writes, storage operations, and AI provider lookup.
SUPABASE_SECRET_KEY=your-supabase-secret-or-service-role-key

# PostgreSQL connection string. Supabase also provides this from Project Settings > Database.
# Use this when running direct PostgreSQL tools, backups, or a future non-Supabase data layer.
DATABASE_URL=postgresql://postgres:password@localhost:5432/pkl_report_system?schema=public

# Any long random string. Used to encrypt AI provider API keys in the database.
AI_CONFIG_SECRET=replace-with-a-long-random-secret
